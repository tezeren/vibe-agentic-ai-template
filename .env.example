# ──────────────────────────────────────────────
# vibe-agentic-ai — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use.
# claude-sonnet-4-5 is the recommended default for agentic tasks.
# Other options: claude-opus-4-5, claude-haiku-3-5, claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Optional: mock mode ──
# Set to "true" to run without making real API calls (useful for demos / CI)
MOCK_MODE=false

# ── Optional: LangSmith tracing ──
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=vibe-agentic-ai
